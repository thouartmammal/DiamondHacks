{
  "manifest_version": 3,
  "name": "Boomer Browse",
  "version": "1.0.0",
  "description": "Works with the Boomer app: save pages, match family photos, and double-check what you read.",
  "permissions": ["tabs", "webNavigation", "windows", "scripting", "activeTab", "storage", "notifications"],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Boomer Browse"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
